CREATE TABLE eh_favorites (
    gid TEXT NOT NULL,
    token TEXT NOT NULL,
    title TEXT NOT NULL,
    category INTEGER NOT NULL DEFAULT 0,
    PRIMARY KEY (gid, token)
);

selectAll:
SELECT * FROM eh_favorites;

insertEhFavorites:
INSERT INTO eh_favorites (title, gid, token, category) VALUES (?, ?, ?, ?);

deleteAll:
DELETE FROM eh_favorites;
