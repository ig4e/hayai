<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <View
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="12dp"
        android:background="@android:color/black" />

    <com.google.android.material.textview.MaterialTextView
        style="?textAppearanceLabelMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/novel_color_red" />
    <com.google.android.material.slider.Slider
        android:id="@+id/red"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="1"
        android:valueFrom="0"
        android:valueTo="255" />

    <com.google.android.material.textview.MaterialTextView
        style="?textAppearanceLabelMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/novel_color_green" />
    <com.google.android.material.slider.Slider
        android:id="@+id/green"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="1"
        android:valueFrom="0"
        android:valueTo="255" />

    <com.google.android.material.textview.MaterialTextView
        style="?textAppearanceLabelMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/novel_color_blue" />
    <com.google.android.material.slider.Slider
        android:id="@+id/blue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="1"
        android:valueFrom="0"
        android:valueTo="255" />

    <com.google.android.material.textview.MaterialTextView
        style="?textAppearanceLabelMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/novel_color_alpha" />
    <com.google.android.material.slider.Slider
        android:id="@+id/alpha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="1"
        android:valueFrom="0"
        android:valueTo="255" />
</LinearLayout>
