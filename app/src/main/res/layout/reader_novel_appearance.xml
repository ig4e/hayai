<?xml version="1.0" encoding="utf-8"?>
<eu.kanade.tachiyomi.ui.reader.settings.NovelAppearanceView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/novel_appearance_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_rounded_background"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/material_component_dialogs_padding_around_content_area"
        android:paddingEnd="@dimen/material_component_dialogs_padding_around_content_area"
        android:paddingTop="0dp"
        android:paddingBottom="16dp">

        <eu.kanade.tachiyomi.widget.MaterialSpinnerView
            android:id="@+id/theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:title="@string/novel_reader_theme" />

        <LinearLayout
            android:id="@+id/font_color_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/novel_font_color"
                android:textColor="?attr/colorOnBackground"
                android:textSize="16sp" />

            <View
                android:id="@+id/font_color_swatch"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/background_color_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/novel_background_color"
                android:textColor="?attr/colorOnBackground"
                android:textSize="16sp" />

            <View
                android:id="@+id/background_color_swatch"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp" />
        </LinearLayout>

        <eu.kanade.tachiyomi.widget.MaterialSpinnerView
            android:id="@+id/chapter_title_display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:title="@string/novel_chapter_title_display" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/hide_chapter_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/novel_hide_chapter_title"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/force_lowercase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/novel_force_lowercase"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/custom_brightness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/use_custom_brightness"
            android:textColor="?attr/colorOnBackground" />

        <include
            android:id="@+id/brightness_value"
            layout="@layout/widget_novel_slider_int" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/keep_screen_on"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/keep_screen_on"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/block_media"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/novel_block_media"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/show_raw_html"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/novel_show_raw_html"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/enable_epub_styles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/novel_enable_epub_styles"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/enable_epub_js"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/novel_enable_epub_js"
            android:textColor="?attr/colorOnBackground" />
    </LinearLayout>
</eu.kanade.tachiyomi.ui.reader.settings.NovelAppearanceView>
