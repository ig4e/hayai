<?xml version="1.0" encoding="utf-8"?>
<eu.kanade.tachiyomi.ui.recents.options.RecentsHistoryView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:id="@+id/sort_layout"
        style="@style/BottomSheetDialogTheme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="vertical"
        android:background="@android:color/transparent">

        <eu.kanade.tachiyomi.widget.MaterialSpinnerView
            android:id="@+id/group_chapters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:entries="@array/group_chapters_together"
            app:title="@string/group_chapters_together" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/collapse_grouped_chapters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/collapse_grouped_chapters"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/show_hidden"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/recents_show_hidden"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.button.MaterialButtonGroup
            android:id="@+id/history_actions_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/hidden_sources"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/recents_hidden_sources" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clear_history"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/clear_history" />
        </com.google.android.material.button.MaterialButtonGroup>
    </LinearLayout>
</eu.kanade.tachiyomi.ui.recents.options.RecentsHistoryView>
